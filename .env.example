# =============================================================================
# Synapse configuration
#
# Usage:  copy this file to `.env` and fill in your values.
#         NEVER commit `.env` — it contains secrets.
#
# All values are read by src/synapse/config/settings.py (pydantic-settings).
# Sections are ordered in the same order you'd set the project up.
# =============================================================================


# =============================================================================
# 1. CORE RUNTIME
# =============================================================================
SYNAPSE_ENVIRONMENT=development         # development | staging | production
SYNAPSE_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
SYNAPSE_LOG_JSON=true                   # true -> JSON logs, false -> console

# Local bring-up helpers:
#   USE_ECHO_GRAPH=true  -> credential-free pipeline smoke test (no LLM needed)
#   ENABLED_WORKERS      -> boot only the integrations you have configured
SYNAPSE_USE_ECHO_GRAPH=false
SYNAPSE_ENABLED_WORKERS=email,calendar,notion,slack

# SQLite checkpointer for conversation state (Module 7)
SYNAPSE_SQLITE_PATH=db/checkpoints.sqlite


# =============================================================================
# 2. TELEGRAM — inbound/outbound messaging (Module 1)          [REQUIRED]
# =============================================================================
SYNAPSE_TELEGRAM_BOT_TOKEN=

# Secret token echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token
# header; used to authenticate inbound webhook calls.
# Generate a long random string.
SYNAPSE_TELEGRAM_WEBHOOK_SECRET=


# =============================================================================
# 3. LLM PROVIDERS (Module 8)                                  [REQUIRED: one]
# =============================================================================
# Only the key(s) for providers you actually use are required.
SYNAPSE_OPENAI_API_KEY=
SYNAPSE_GOOGLE_API_KEY=                 # Gemini
SYNAPSE_GROQ_API_KEY=

# --- Defaults ----------------------------------------------------------------
SYNAPSE_DEFAULT_LLM_PROVIDER=openai     # openai | gemini | groq
SYNAPSE_DEFAULT_LLM_MODEL=gpt-4o
SYNAPSE_DEFAULT_LLM_TEMPERATURE=0.0

# The agents depend on reliable tool-calling. Verified working models:
#   openai -> gpt-4o
#   groq   -> openai/gpt-oss-120b
# AVOID groq + llama-3.3-70b-versatile: it emits malformed function calls and
# Groq rejects them with `tool_use_failed` (verified).

# --- Optional per-agent overrides (fall back to defaults when unset) ----------
# SYNAPSE_MANAGER_LLM_MODEL=gpt-4o
# SYNAPSE_EMAIL_LLM_MODEL=gpt-4o-mini
# SYNAPSE_CALENDAR_LLM_MODEL=gpt-4o-mini
# SYNAPSE_NOTION_LLM_MODEL=gpt-4o-mini
# SYNAPSE_SLACK_LLM_MODEL=gpt-4o-mini


# =============================================================================
# 4. GOOGLE OAUTH — shared by Email + Calendar agents          [REQUIRED for both]
# =============================================================================
# OAuth client secret file and the stored user token produced by the one-time
# OAuth consent (scripts/setup_google_oauth.py). The token MUST be granted the
# union of all Google scopes used:
#   gmail.readonly + contacts.readonly + calendar
SYNAPSE_GOOGLE_CREDENTIALS_PATH=credentials.json
SYNAPSE_GOOGLE_TOKEN_PATH=token.json


# =============================================================================
# 5. AGENT: CALENDAR — Google Calendar (Module 4)
# =============================================================================
# Reuses the Google OAuth token above (calendar scope).
# "primary" = the user's main calendar.
SYNAPSE_CALENDAR_ID=primary
SYNAPSE_CALENDAR_MAX_RESULTS=10


# =============================================================================
# 6. AGENT: EMAIL — Gmail read + SMTP send (Module 3)
# =============================================================================
# Reading uses the Google OAuth token above (gmail.readonly + contacts.readonly).
SYNAPSE_GMAIL_MAX_RESULTS=5

# Sending uses SMTP with a Gmail App Password (NOT OAuth).
SYNAPSE_SMTP_HOST=smtp.gmail.com
SYNAPSE_SMTP_PORT=465
SYNAPSE_SMTP_USERNAME=
SYNAPSE_SMTP_APP_PASSWORD=


# =============================================================================
# 7. AGENT: NOTION — to-do database (Module 5)
# =============================================================================
# Internal integration token (secret_...) and the target database id.
# The database must have these exact properties:
#   Title  (Title)
#   Status (Status: "Not started" / "In progress" / "Done")
#   Date   (Date)
SYNAPSE_NOTION_API_KEY=
SYNAPSE_NOTION_DATABASE_ID=
SYNAPSE_NOTION_MAX_RESULTS=25


# =============================================================================
# 8. AGENT: SLACK — team messaging (Module 6)
# =============================================================================
# Bot token (xoxb-...) with scopes:
#   channels:read, groups:read, channels:history, groups:history, chat:write
# The bot must be invited to any channel it posts to.
SYNAPSE_SLACK_BOT_TOKEN=
SYNAPSE_SLACK_MAX_HISTORY=10


# =============================================================================
# 9. SAFETY & OBSERVABILITY
# =============================================================================
# Human-in-the-loop approval (Module 7): when true, outbound actions
# (send email, create event, create task, post to Slack) pause for a
# yes/no confirmation before executing.
SYNAPSE_REQUIRE_APPROVAL_FOR_WRITES=true

# LangSmith tracing (Module 8)
SYNAPSE_LANGSMITH_TRACING=false
SYNAPSE_LANGSMITH_API_KEY=
SYNAPSE_LANGSMITH_PROJECT=synapse
